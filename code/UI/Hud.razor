@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<root>
	<img class="role-icon" src="@RoleIcon" />
</root>

@code
{
	private RoleTrashCompactor LocalRole => Player.Local?.RoleEnum ?? RoleTrashCompactor.Survival;

	private string RoleIcon => LocalRole switch
	{
		RoleTrashCompactor.Trashman => "materials/icons/trashman.vtex",
		RoleTrashCompactor.Spectator => "materials/icons/spectator.vtex",
		_ => "materials/icons/survival.vtex"
	};

	protected override int BuildHash() => System.HashCode.Combine( LocalRole );
}
